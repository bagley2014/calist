{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"allowJs": false,
		"skipLibCheck": true,
		"types": ["bun-types", "vite/client"],
		"baseUrl": ".",
		"paths": { "@shared/*": ["src/shared/*"] }
	},
	"include": ["src", "vite.config.ts", "drizzle.config.ts"]
}
