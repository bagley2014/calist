{
	"name": "calist",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"repository": "https://github.com/bagley2014/calist",
	"scripts": {
		"dev": "bunx concurrently -k \"bun run dev:server\" \"bun run dev:client\"",
		"dev:server": "bun --watch src/server/index.ts",
		"dev:client": "bunx vite --config vite.config.ts",
		"build": "bunx vite build --config vite.config.ts",
		"check": "bunx tsc --noEmit",
		"migrate": "bun run src/server/db/migrate.ts",
		"test": "bunx vitest run",
		"test:watch": "bunx vitest",
		"lint": "bunx prettier --check \"src/**/*.{js,ts,tsx,jsx,json,css,less,md}\"",
		"format": "bunx prettier --write \"src/**/*.{js,ts,tsx,jsx,json,css,less,md}\""
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@fastify/static": "^8.3.0",
		"chrono-node": "^2.9.0",
		"drizzle-orm": "^0.44.6",
		"fastify": "^5.6.1",
		"bcryptjs": "^3.0.2",
		"jsonwebtoken": "^9.0.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"rrule": "^2.8.1"
	},
	"devDependencies": {
		"@types/jsonwebtoken": "^9.0.10",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@vitejs/plugin-react": "^5.0.4",
		"bun-types": "^1.3.10",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.5",
		"less": "^4.6.4",
		"prettier": "^3.8.2",
		"typescript": "^5.9.3",
		"vite": "^7.1.12",
		"vitest": "^4.1.4"
	}
}
